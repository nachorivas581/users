  mediaMeta:  { color: T.color.textMuted, fontSize: IS_TV ? fs(13) : T.font.xs, marginBottom: T.space.xs },
  ratingBadge: {
    alignSelf: 'flex-start', borderRadius: T.radius.sm,
    paddingHorizontal: T.space.sm, paddingVertical: 2,
  },
  ratingText: { fontSize: IS_TV ? fs(13) : T.font.xs, fontWeight: T.font.bold },
  mediaCardBadge: {
    position: 'absolute', top: T.space.sm, right: T.space.sm,
    backgroundColor: T.color.primary, paddingHorizontal: T.space.xs + 1,
    paddingVertical: 2, borderRadius: T.radius.sm,
  },
  mediaCardBadgeText: { fontSize: 9, fontWeight: T.font.black, color: '#fff', letterSpacing: 0.5 },

  /* ── Ajustes ─────────────────────────────────────────── */
  settingItem: {
    flexDirection: 'row', justifyContent: 'space-between', alignItems: 'center',
    backgroundColor: T.color.surface, borderRadius: IS_TV ? T.radius.lg : T.radius.md,
    padding: IS_TV ? s(22) : T.space.lg, marginBottom: IS_TV ? T.space.lg : T.space.md,
    borderWidth: 1, borderColor: T.color.border,
  },
  settingLabel: { color: T.color.textPrimary, fontSize: IS_TV ? fs(20) : T.font.md, fontWeight: T.font.semibold },
